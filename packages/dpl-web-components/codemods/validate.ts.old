/**
 * CLI tool to validate all codemods against safety & correctness criteria.
 *
 * Usage (after codemods:build):
 *   node codemods/dist/validate.js
 *   node codemods/dist/validate.js --strict
 *   node codemods/dist/validate.js --transform rename-dpl-button-variant-outline-to-ghost
 *   node codemods/dist/validate.js --fix
 *
 * Or via Nx target:
 *   nx run dpl-web-components:codemods:validate
 *   nx run dpl-web-components:codemods:validate -- --strict
 *   nx run dpl-web-components:codemods:validate -- --transform <id> --fix
 */

import * as fs from 'fs';
import * as path from 'path';
import { validateManifest } from './validators/manifest-validator';
import { validateTransformModule } from './validators/transform-validator';
import { validateFixtures } from './validators/fixture-validator';

interface CliArgs {
  strict: boolean;
  transform?: string;
  fix: boolean;
  help: boolean;
}

function parseArgs(argv: string[]): CliArgs {
  const result: CliArgs = { strict: false, fix: false, help: false };

  for (let i = 0; i < argv.length; i++) {
    const arg = argv[i];

    if (arg === '--strict') {
      result.strict = true;
    } else if (arg === '--fix') {
      result.fix = true;
    } else if (arg === '--help' || arg === '-h') {
      result.help = true;
    } else if (arg === '--transform' && i + 1 < argv.length) {
      result.transform = argv[++i];
    } else if (arg.startsWith('--transform=')) {
      result.transform = arg.slice(11);
    }
  }

  return result;
}

function printHelp(): void {
  console.log(`
Codemod Validation CLI

Usage: node codemods/dist/validate.js [options]

Options:
  --strict               Treat warnings as errors. Exit with code 1 if any issues found.
  --transform <id>      Validate only a specific transform (use multiple times for multiple).
  --fix                  Auto-fix issues where possible (not yet implemented).
  --help, -h            Show this help.

Examples:
  node codemods/dist/validate.js
  node codemods/dist/validate.js --strict
  node codemods/dist/validate.js --transform rename-dpl-button-variant-outline-to-ghost
  node codemods/dist/validate.js --strict --transform rename-dpl-button-variant-outline-to-ghost --fix
`);
}

async function main(): Promise<void> {
  const args = parseArgs(process.argv.slice(2));

  if (args.help) {
    printHelp();
    process.exit(0);
  }

  const codemods = path.resolve(__dirname, '.');
  const manifestPath = path.join(codemods, 'manifest.ts');

  let manifest: any;
  try {
    // eslint-disable-next-line @typescript-eslint/no-var-requires
    const manifestModule = require('./manifest');
    manifest = manifestModule.default;
  } catch (e) {
    console.error('❌ Failed to load manifest:', (e as Error).message);
    process.exit(1);
  }

  console.log('🔍 Validating codemods...\n');

  // 1. Validate manifest
  console.log('1️⃣  Manifest validation...');
  const manifestResult = validateManifest(manifest, codemods);
  printValidationResult('Manifest', manifestResult, args.strict);

  let hasErrors = !manifestResult.valid;

  // 2. Validate each transform
  console.log('\n2️⃣  Transform validation...');
  for (const entry of manifest) {
    if (args.transform && entry.id !== args.transform) continue;

    const transformPath = path.resolve(codemods, entry.transformPath + '.ts');
    const transformDist = path.resolve(codemods, entry.transformPath + '.js');

    // Try to load compiled version first, then source
    const toValidate = fs.existsSync(transformDist) ? transformDist : transformPath;

    const result = validateTransformModule(toValidate);
    if (!printValidationResult(`Transform: ${entry.id}`, result, args.strict)) {
      hasErrors = true;
    }

    // 3. Validate fixtures
    const transformDir = path.dirname(transformPath);
    const fixturesResult = validateFixtures(transformDir);
    if (!printValidationResult(`  Fixtures: ${entry.id}`, fixturesResult, args.strict)) {
      hasErrors = true;
    }
  }

  console.log('\n' + '='.repeat(60));
  if (hasErrors) {
    console.log('❌ Validation failed. Fix the errors above before publishing.\n');
    process.exit(args.strict ? 1 : 0);
  } else {
    console.log('✅ All codemods passed validation!\n');
    process.exit(0);
  }
}

function printValidationResult(
  label: string,
  result: { valid: boolean; errors: string[]; warnings: string[] },
  strict: boolean,
): boolean {
  const icon = result.valid ? '✅' : '❌';
  console.log(`  ${icon} ${label}`);

  if (result.errors.length > 0) {
    for (const error of result.errors) {
      console.log(`     ❌ ${error}`);
    }
  }

  if (result.warnings.length > 0) {
    for (const warning of result.warnings) {
      console.log(`     ⚠️  ${warning}`);
    }
  }

  if (result.errors.length === 0 && result.warnings.length === 0) {
    return true;
  }

  if (strict && (result.errors.length > 0 || result.warnings.length > 0)) {
    return false;
  }

  return result.valid;
}

main().catch((err) => {
  console.error('Error:', (err as Error).message);
  process.exit(1);
});
