{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "h.Fragment",
    "types": ["node"]
  },
  "include": [
    "manifest.ts",
    "cli.ts",
    "utils/**/*.ts",
    "transforms/**/*.ts"
  ],
  "exclude": [
    "**/__tests__/**",
    "**/fixtures/**",
    "node_modules",
    "dist"
  ]
}
