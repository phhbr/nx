{
  "name": "@designsystem/migrations",
  "version": "1.0.0",
  "description": "Version-aware migration runner for @designsystem/dpl-web-components",
  "private": false,
  "bin": {
    "migrations": "./bin/migrations.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest --config jest.config.cjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@designsystem/dpl-web-components": "workspace:*",
    "glob": "^10.0.0",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/semver": "^7.0.0",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=18.14.0"
  },
  "keywords": [
    "codemod",
    "migrations",
    "dpl",
    "designsystem"
  ]
}
